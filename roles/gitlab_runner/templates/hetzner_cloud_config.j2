
package_update: true
package_upgrade: true
{% if gitlab_runner_hetzner_docker_storage_driver | default('') | length > 0 %}

# Force storage driver to work around containerd image store bug
# in Docker 29.x (see #15045)
write_files:
  - path: /etc/docker/daemon.json
    content: |
      {
        "storage-driver": "{{ gitlab_runner_hetzner_docker_storage_driver }}"
      }
{% endif %}

apt:
  sources:
    docker.list:
      source: deb [signed-by=$KEY_FILE] https://download.docker.com/linux/debian $RELEASE stable
      keyid: 9DC858229FC7DD38854AE2D88D81803C0EBFCD88

packages:
  - ca-certificates
  - docker-ce

swap:
  filename: /var/swap.bin
  size: auto
  maxsize: 4294967296 # 4GB
